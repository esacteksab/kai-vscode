{
  "name": "esacteksab-kai",
  "displayName": "esacteksab kai",
  "description": "Slightly modified high contrast theme based on Sonokai from sainnhe",
  "version": "0.0.7",
  "publisher": "esacteksab",
  "author": "esacteksab (https://github.com/esacteksab)",
  "homepage": "https://github.com/esacteksab/kai-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/esacteksab/kai-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/esacteksab/kai-vscode/issues"
  },
  "license": "MIT",
  "keywords": [
    "monokai",
    "theme",
    "AAA",
    "AA",
    "WCAG"
  ],
  "icon": "./assets/ppp-sized.png",
  "galleryBanner": {
    "color": "#2a2f38",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.43.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "esacteksab kai",
        "uiTheme": "vs-dark",
        "path": "./themes/esacteksab-kai-default.json"
      },
      {
        "label": "esacteksab kai atlantis",
        "uiTheme": "vs-dark",
        "path": "./themes/esacteksab-kai-atlantis.json"
      },
      {
        "label": "esacteksab kai vivid",
        "uiTheme": "vs-dark",
        "path": "./themes/esacteksab-kai-vivid.json"
      }
    ]
  },
  "files": [
    "themes/**",
    "assets/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "validate:themes": "node scripts/validate-themes.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "prettier": "^3.8.2",
    "prettier-plugin-pkg": "^0.22.0"
  }
}
